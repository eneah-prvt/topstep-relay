# Executor (runs on YOUR laptop — this is where trades originate)

# --- Relay connection ---
RELAY_URL=wss://your-relay.up.railway.app
RELAY_TOKEN=change-me-another-long-random-string   # must equal EXECUTOR_TOKEN on the relay

# --- Topstep / ProjectX credentials ---
PROJECTX_BASE=https://api.topstepx.com
PROJECTX_USERNAME=your-topstepx-username
PROJECTX_API_KEY=your-projectx-api-key
# Optional: pin the account. Leave blank to auto-use the first active account.
PROJECTX_ACCOUNT_ID=

# --- Contract mapping (front-month contract IDs) ---
# Update these when contracts roll. You can also send "contractId" directly in a signal.
CONTRACTS={"NQ":"CON.F.US.ENQ.U25","ES":"CON.F.US.EP.U25"}

# --- Safety ---
DRY_RUN=true              # START HERE. Set to false only after you've watched dry-run logs.
MAX_SIZE=5                # reject any signal larger than this
ALLOWED_SYMBOLS=NQ,ES     # empty = allow all
